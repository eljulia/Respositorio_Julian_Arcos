# Notion Integration
# Obtén el token en: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# ID de la base de datos "Contactos Portafolio" en Notion
# Se obtiene desde la URL de la DB: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_CONTACTS_DB_ID=

# ID de la página Resume que contiene el PDF del CV en Notion
NOTION_RESUME_PAGE_ID=
